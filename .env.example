# Backend configuration
BACKEND_URL=http://localhost:3000

# App configuration
APP_URL=https://app.smarteat.fr/login

# Email configuration (Netlify functions)
EMAIL_USERNAME=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password

# Analytics configuration
# Get your Google Analytics ID from https://analytics.google.com/
# Format: G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=

# HotJar configuration (optional)
# Get your HotJar ID from https://insights.hotjar.com/
# Just the numeric ID
HOTJAR_ID=
